generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model TeamMember {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String
  password   String
  lineUserId String?
  lineLinkCode String? @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("team_members")
}

model Provider {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?
  calendarId         String?
  avatarUrl          String?
  lineUserId         String?
  lineLinkCode       String?   @unique
  password           String?
  role               String    @default("provider") // "provider" | "admin"
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  availabilities   Availability[]
  bookings         Booking[]
  providerServices ProviderService[]

  @@map("providers")
}

model Service {
  id             String  @id @default(cuid())
  name           String
  description    String?
  duration         Int
  bufferBefore     Int     @default(0)  // minutes before booking
  bufferAfter      Int     @default(0)  // minutes after booking
  slotInterval     Int     @default(30) // slot granularity in minutes (15, 30, 60)
  bookingWindowDays Int     @default(14)
  minAdvanceDays    Int     @default(0) // 最少提前幾天預約 (0=不限制)
  assignmentMode      String  @default("manual") // "manual" | "round_robin"
  showProviderSelection  Boolean @default(false)
  hasDisclaimer          Boolean @default(false)
  disclaimerText         String? // 行前說明/注意事項
  requiresApproval       Boolean @default(false)
  approvalMessageLine    String? // 審核通過 LINE 訊息
  approvalMessageEmail   String? // 審核通過 Email 訊息
  rejectionMessageLine   String? // 審核不通過 LINE 訊息
  rejectionMessageEmail  String? // 審核不通過 Email 訊息
  approvalNotifyLine     Boolean @default(true)
  approvalNotifyEmail    Boolean @default(false)
  rejectionNotifyLine    Boolean @default(true)
  rejectionNotifyEmail   Boolean @default(false)
  /// 預約成功通知訊息
  bookingConfirmMessage       String? // 通知客戶的訊息
  bookingConfirmProviderMsg   String? // 通知提供者的訊息
  /// 預約成功通知管理員
  notifyAdminOnBooking   Boolean @default(false)
  adminBookingMessage    String? // 通知管理員的訊息
  /// 更改時段通知
  rescheduleCustomerMsg  String? // 更改時段通知客戶
  rescheduleProviderMsg  String? // 更改時段通知提供者
  rescheduleAdminMsg     String? // 更改時段通知管理員
  /// 取消預約通知
  cancelCustomerMsg      String? // 取消通知客戶
  cancelProviderMsg      String? // 取消通知提供者
  cancelAdminMsg         String? // 取消通知管理員
  /// 定價與支付
  price            Int     @default(0)  // 服務定價（0=免費）
  acceptTicket     Boolean @default(false) // 是否接受票券
  acceptPoints     Boolean @default(false) // 是否接受點數抵扣
  pointsPerUnit    Int     @default(1)  // 1 點 = 多少元（預設 1:1）
  isActive               Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bookings         Booking[]
  providerServices ProviderService[]
  formFields       FormField[]
  customerTickets  CustomerTicket[]

  @@map("services")
}

model ProviderService {
  providerId String
  serviceId  String

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([providerId, serviceId])
  @@map("provider_services")
}

model Customer {
  id           String   @id @default(cuid())
  lineUserId   String   @unique
  displayName  String?
  email        String?
  isBlocked    Boolean  @default(false)
  blockedAt    DateTime?
  blockReason  String?
  phone        String?
  notes        String?
  pictureUrl   String?
  points       Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tickets CustomerTicket[]

  @@map("customers")
}

model CustomerTicket {
  id          String    @id @default(cuid())
  customerId  String
  serviceId   String
  total       Int       // 總張數
  used        Int       @default(0) // 已使用
  expiresAt   DateTime? // 到期日（null=永不過期）
  promotionId String?   // reference to promotion if this ticket was granted via promotion
  notes       String?
  createdAt   DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id])

  @@index([promotionId])
  @@map("customer_tickets")
}

model PointTransaction {
  id          String   @id @default(cuid())
  customerId  String
  amount      Int      // 正數=加點, 負數=扣點
  reason      String   // "purchase" | "booking" | "refund" | "admin_adjust" | "reward"
  bookingId   String?
  promotionId String?  // reference to promotion if this is a promotion reward
  notes       String?
  createdAt   DateTime @default(now())

  @@index([customerId])
  @@index([promotionId])
  @@map("point_transactions")
}

model Promotion {
  id          String   @id @default(cuid())
  name        String
  description String?
  /// 適用服務（JSON array of service IDs, null = 全部）
  serviceIds  String?
  /// 獎勵類型
  rewardType  String   // "points" | "tickets" | "both"
  rewardPoints Int     @default(0)
  rewardTickets Int    @default(0)
  /// 贈送票券的目標服務（rewardType 包含 tickets 時使用）
  ticketServiceId String?
  /// 活動期間
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("promotions")
}

model Availability {
  id           String  @id @default(cuid())
  providerId   String
  dayOfWeek    Int     // 0-6 for Sun-Sat, 7 for "every day"
  startTime    String
  endTime      String
  type         String  @default("available") // "available" | "excluded"
  specificDate String? // for specific date exclusions, e.g. "2026-04-10"
  bufferBefore Int     @default(0) // minutes before slot
  bufferAfter  Int     @default(0) // minutes after slot

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("availabilities")
}

model Booking {
  id            String    @id @default(cuid())
  providerId    String
  serviceId     String
  lineUserId    String
  customerName  String
  customerPhone String
  date          DateTime
  startTime     String
  endTime       String
  status        String    @default("confirmed")
  googleEventId String?
  googleMeetUrl String?
  notes         String?
  paidWith      String?   // "ticket" | "points" | null (free)
  ticketId      String?   // reference to CustomerTicket used
  pointsUsed    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  provider  Provider   @relation(fields: [providerId], references: [id])
  service   Service    @relation(fields: [serviceId], references: [id])
  reminders Reminder[]

  @@index([providerId, date])
  @@index([lineUserId])
  @@map("bookings")
}

model Reminder {
  id            String    @id @default(cuid())
  bookingId     String
  type          String
  minutesBefore Int
  scheduledAt   DateTime
  sentAt        DateTime?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([scheduledAt, sentAt])
  @@map("reminders")
}

model ReminderRule {
  id                      String  @id @default(cuid())
  serviceId               String?
  serviceIds              String? // JSON array of service IDs (takes precedence over serviceId); null/empty = all services
  type                    String
  timing                  String  @default("before") // "before" | "after"
  minutesBefore           Int
  notifyCustomer          Boolean @default(true)
  messageTemplate         String?
  notifyProvider          Boolean @default(false)
  providerMessageTemplate String?
  notifyAdmin             Boolean @default(false)
  adminMessageTemplate    String?
  isActive                Boolean @default(true)

  @@map("reminder_rules")
}

model SiteSettings {
  id    String @id @default("default")
  /// JSON: which fields to show on confirmation page
  /// e.g. ["service","provider","date","time","name","phone","notes"]
  confirmationFields String @default("[\"service\",\"provider\",\"date\",\"time\",\"name\",\"phone\"]")
  /// Color theme: "blue" | "teal" | "purple" | "custom"
  colorTheme    String @default("blue")
  /// Custom colors (hex) — used when colorTheme is "custom"
  customPrimary String @default("#2563EB")
  customAccent  String @default("#06B6D4")
  /// How many days ahead customers can book (0 = unlimited)
  bookingWindowDays  Int     @default(14)
  showProviderAvatar Boolean @default(true)
  /// Store front settings
  showStoreFront     Boolean @default(false)
  storeName          String  @default("")
  storeDescription   String  @default("")
  storeImageUrl      String?
  storeMediaType     String  @default("none") // "none" | "image" | "youtube"
  storeYoutubeUrl    String?
  /// 點數回饋
  rewardPointsOnComplete Int @default(0)

  @@map("site_settings")
}

model FormField {
  id        String  @id @default(cuid())
  serviceId String
  key       String
  label     String
  type      String  // "text" | "textarea" | "radio" | "checkbox"
  options   String? // JSON array for radio/checkbox
  required  Boolean @default(false)
  enabled   Boolean @default(true)
  sortOrder Int     @default(0)
  isBuiltin Boolean @default(false)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, key])
  @@map("form_fields")
}
